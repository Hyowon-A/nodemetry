# Database
DB_URL=jdbc:postgresql://localhost:5432/nodemetry
DB_USERNAME=nodemetry
DB_PASSWORD=change-me

# MQTT ingest
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=8883
MQTT_USERNAME=change-me
MQTT_PASSWORD=change-me
MQTT_CLIENT_ID=nodemetry-backend-local

# Frontend and API behavior
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
HTTP_API_READ_ONLY=false

# Optional ingest tuning
TELEMETRY_INGEST_QUEUE_CAPACITY=50000
TELEMETRY_INGEST_BATCH_SIZE=500
TELEMETRY_INGEST_FLUSH_INTERVAL_MS=100

# Optional run-metric tuning
RUN_METRICS_VIRTUAL_NODE_PREFIXES=vnode-
RUN_METRICS_PHYSICAL_IDLE_EVICT_MS=60000
RUN_METRICS_END_GRACE_MS=15000
